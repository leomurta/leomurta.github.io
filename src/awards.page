  display: flex;
  flex-direction: column;
  align-items: center;
}
.award-tile img {
  width: 200px;
  max-height: 260px;
  height: auto;
  object-fit: contain;
  background: #fff;
  border: 1px solid #ddd;
  padding: 3px;
}
.award-tile:hover img { border-color: #286ea0; }
.award-caption {
  font-size: 0.82em;
  line-height: 1.3em;
  margin-top: 6px;
  text-align: center;
}
.award-year { font-weight: 700; }
</style>

