<div class="awards-mosaic">
<% awards.each do |a|
     pdf_url   = context.tag(:relocatable, "awards/#{a[:pdf]}")
     thumb_url = context.tag(:relocatable, "awards/thumbnails/#{a[:pdf].sub(/\.pdf\z/, '.jpg')}")
%>
  <a class="award-tile" href="<%= pdf_url %>" target="_blank" rel="noopener">
    <img src="<%= thumb_url %>" alt="<%= a[:nome] %>" title="<%= a[:nome] %>"/>
    <div class="award-caption">
      <%= a[:nome] %><br/>
      <%= a[:entidade] %><br/>
      <span class="award-year"><%= a[:ano] %></span>
    </div>
  </a>
